    replacement_chunks {
      replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \"Inter\", ui-sans-serif, system-ui, sans-serif;\n  --font-display: \"Space Grotesk\", sans-serif;\n  --font-mono: \"JetBrains Mono\", monospace;\n\n  /* Theme mappings for Tailwind v4 utility values */\n  --color-bg-page: var(--background);\n  --color-surf-lowest: var(--surface-lowest);\n  --color-surf-low: var(--surface-low);\n  --color-surf-mid: var(--surface);\n  --color-surf-high: var(--surface-high);\n  --color-surf-highest: var(--surface-highest);\n  \n  --color-txt-high: var(--text-high);\n  --color-txt-mid: var(--text-medium);\n  --color-txt-low: var(--text-low);\n  \n  --color-emerald-accent: var(--emerald-accent);\n  --color-emerald-glow: var(--emerald-accent-glow);\n  --color-emerald-hover: var(--emerald-accent-hover);\n  \n  --color-electric-blue: var(--electric-blue);\n  --color-border-custom: var(--border-color);\n\n  /* Animation durations & curves */\n  --animate-fade-in: fade-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n  --animate-slide-up: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n  \n  @keyframes fade-in {\n    from { opacity: 0; }\n    to { opacity: 1; }\n  }\n  @keyframes slide-up {\n    from { opacity: 0; transform: translateY(30px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n}\n\n:root {\n  --background: #f8fafc;\n  --surface-lowest: #ffffff;\n  --surface-low: #f1f5f9;\n  --surface: rgba(226, 232, 240, 0.6);\n  --surface-high: #cbd5e1;\n  --surface-highest: #94a3b8;\n  \n  --text-high: #0f172a;\n  --text-medium: #475569;\n  --text-low: #64748b;\n  \n  --emerald-accent: #0f766e; /* Accessible high-contrast teal-green for light mode */\n  --emerald-accent-glow: rgba(15, 118, 110, 0.1);\n  --emerald-accent-hover: #115e59;\n  \n  --electric-blue: #0284c7;\n  --border-color: rgba(148, 163, 184, 0.2);\n}\n\n.dark {\n  --background: #0b1326;\n  --surface-lowest: #060e20;\n  --surface-low: #131b2e;\n  --surface: rgba(23, 31, 51, 0.5);\n  --surface-high: #222a3d;\n  --surface-highest: #2d3449;\n  \n  --text-high: #dae2fd;\n  --text-medium: #94a3b8;\n  --text-low: #475569;\n  \n  --emerald-accent: #5dd3b3; /* Vibrant futuristic green for dark mode */\n  --emerald-accent-glow: rgba(93, 211, 179, 0.15);\n  --emerald-accent-hover: #7bf0ce;\n  \n  --electric-blue: #38bdf8;\n  --border-color: rgba(71, 85, 105, 0.25);\n}\n\nbody {\n  background-color: var(--background);\n  color: var(--text-high);\n  font-family: var(--font-sans);\n  transition: background-color 0.4s ease, color 0.4s ease, border-color 0.4s ease;\n  scroll-behavior: smooth;\n  overflow-x: hidden;\n}\n\n/* Fluid navigation link styling */\n.nav-link {\n  position: relative;\n  transition: color 0.3s ease;\n}\n\n.nav-link::after {\n  content: \'\';\n  position: absolute;\n  width: 0;\n  height: 2px;\n  bottom: -4px;\n  left: 0;\n  background-color: var(--emerald-accent);\n  transition: width 0.3s ease;\n}\n\n.nav-link:hover::after,\n.nav-link.active::after {\n  width: 100%;\n}\n\n/* Custom scrollbars */\n::-webkit-scrollbar {\n  width: 8px;\n}\n::-webkit-scrollbar-track {\n  background: var(--background);\n}\n::-webkit-scrollbar-thumb {\n  background: var(--surface-high);\n  border-radius: 4px;\n}\n::-webkit-scrollbar-thumb:hover {\n  background: var(--surface-highest);\n}\n"
    }
